@page "/BaseOil"
@inject ILogger<DrillingFluidMain> logger
@inject ISnackbar Snackbar
<MudUnitAndReferenceChoiceTag HttpHost=@APIUtils.HostNameUnitConversion
        HttpBasePath=@APIUtils.HostBasePathUnitConversion
        HttpController="UnitSystem/"
        UnitSystemName="@DataUtils.UnitAndReferenceParameters.UnitSystemName"
        UnitSystemNameChanged="@DataUtils.UpdateUnitSystemName">
    @if (baseOilList == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {     

        
        <MudToolBar>
            <MudText Typo="Typo.h5"> Base Oil Description @baseOilMessage </MudText>
            <MudSpacer/>
            <MudButton StartIcon="@Icons.Material.Outlined.Delete" 
                IconColor="@Color.Error" OnClick="@DeleteSelectedBaseOil">Delete selection</MudButton>     
            <MudButton StartIcon="@Icons.Material.Outlined.Add"    
                IconColor="@Color.Success" OnClick="@AddBaseOil">Add Base Oil element</MudButton>
     
        </MudToolBar>
        <MudDataGrid T="BaseOil" MultiSelection="true" Items="@baseOilList" SelectedItemsChanged="@SelectedItemsChanged"
                EditMode="DataGridEditMode.Cell"
                Hover="true"
                SortMode="SortMode.Multiple" QuickFilter="@_baseOilFilter" Filterable="false">
            <Columns>
                <SelectColumn T="BaseOil" />
                <PropertyColumn Property="x => x.Name" Title="Name" CellStyle="width: 20%;" Sortable="true" Editable="false" />
                <PropertyColumn Property="x => x.Description" Title="Description" CellStyle="width: 60%;" Sortable="true" Editable="false" />         
                <TemplateColumn>
                    <CellTemplate>
                        <MudIconButton Class="mx-2" Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" 
                            OnClick="(() => EditBaseOil(context.Item.MetaInfo.ID))" />                                                                                                             
                        <MudIconButton Size="@Size.Medium" Icon="@Icons.Material.Outlined.Delete" 
                            OnClick="(() => DeleteBaseOil(context.Item.MetaInfo.ID))"/>                            
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="BaseOil" />
            </PagerContent>
        </MudDataGrid>
    }
    @if(showAddPanel)
    {
        <BaseOilAddAndEdit BaseOilId="@baseOilIdForEdit" OnMessageSent="@HandleBaseOilAddition"/>
    }
</MudUnitAndReferenceChoiceTag>


@code{
    private List<BaseOil> baseOilList = new();
    private List<BaseOil> selectedBaseOilList = new();
    [Inject] private IDialogService DialogService { get; set; }
    private Guid? baseOilIdForEdit;
    private bool showAddPanel = false;
    private string? _searchString;
    private string baseOilMessage = "";
    protected override async Task OnInitializedAsync()
    {

        // Starting all loading tasks asynchronously
        logger.LogInformation("Trying to load list of BaseOil from client: " + APIUtils.HttpClientDrillingFluid);
        var baseOilTask = APIUtils.ClientDrillingFluid.GetAllBaseOilAsync();

        List<Task> loadingTaskList = new List<Task> { baseOilTask };
        Task finishedTask = await Task.WhenAny(loadingTaskList);
        if (finishedTask == baseOilTask)
        {
            try
            {
                baseOilList = (List<BaseOil>)await baseOilTask; // awaiting the finished task allows to retrieve its result and throw exception if needed
                if (baseOilList != null)
                {
                    baseOilList.Sort((f1, f2) => f1.Name.CompareTo(f2.Name));
                }
                else
                {
                    logger.LogWarning("Returned list of Drilling Fluid Description were null on initialization");
                    Snackbar.Add("Returned list of Drilling Fluid Description were null on initialization", Severity.Warning);
                }
            }
            catch (ApiException ex)
            {
                logger.LogError(ex, "Impossible to load Drilling Fluid Description from client");
            }
        }

        await InvokeAsync(() => { StateHasChanged(); });
    }
    protected override void OnParametersSet()
    {
        showAddPanel = false;
    }
    private Func<BaseOil, bool>
    _baseOilFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;
        if ($"{x.Name} {x.Description}".Contains(_searchString))
            return true;

        return false;
    };
    void SelectedItemsChanged(HashSet<BaseOil>items)
    {
        selectedBaseOilList.Clear();
        selectedBaseOilList.InsertRange(0, items);
    }
    private async Task HandleBaseOilAddition()
    {
        showAddPanel = false;
        await OnInitializedAsync();
    }
    private void AddBaseOil()
    {
        showAddPanel = true;
        baseOilIdForEdit = null;
    }
    private void EditBaseOil(Guid id)
    {
        baseOilIdForEdit = id;
        showAddPanel = true;
    }
    private async Task DeleteBaseOil(Guid id)
    {
        try
        {
            if (await ConfirmDeletion())
            {
                await APIUtils.ClientDrillingFluid.DeleteBaseOilByIdAsync(id);
                await OnInitializedAsync();
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to delete DrillingFluid");
        }
    }
    private async Task DeleteSelectedBaseOil()
    {
        if (await ConfirmDeletion())
        {
            foreach (BaseOil baseOil in selectedBaseOilList)
            {
                await APIUtils.ClientDrillingFluid.DeleteBaseOilByIdAsync(baseOil.MetaInfo.ID);
                await OnInitializedAsync();
            }
            selectedBaseOilList.Clear();
        }        
    }
    private async Task<bool> ConfirmDeletion()
    {
        var options = new DialogOptions 
        { 
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true    
        };
        var dialog = await DialogService.ShowAsync<DialogDeleteTemplate>("DELETE", options);
        var result = await dialog.Result;
        StateHasChanged();
        if (result == null)
        {
            return false;
        }
        else
        {
            return (!result.Canceled);
        }
    }
    async void OnClickCloseEditPanel() {
        showAddPanel = false;
        baseOilIdForEdit = null;
        await InvokeAsync(() => { StateHasChanged(); });
    }


}
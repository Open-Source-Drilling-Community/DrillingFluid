        @* Create table *@
        <MudTable Class="my-4 py-2 mx-4 px-2" Items="@valueData" Height="350px"  HorizontalScrollbar="true">
            <ColGroup>
                @for(int i = 0; i < maxColumns; i++)
                {
                    <col style="min-width: 150px;" />
                }
            </ColGroup>
            <HeaderContent>
                @for(int i = 0; i < maxColumns; i++)
                {
                    int index = i;
                    <MudTh>@((index + 1) + " - " + headerData[index])</MudTh>
                }
            </HeaderContent>
            <RowTemplate>
                @for(int i = 0; i < maxColumns; i++)
                {
                    int index = i;
                    <MudTd>@context[index]</MudTd>
                }
            </RowTemplate>
        </MudTable>    

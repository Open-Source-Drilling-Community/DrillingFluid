    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        fileName = file.Name;
        int index = fileName.LastIndexOf('.');
        fileName = index == -1 ? fileName : fileName.Substring(0, index);
        if (file != null)
        {
            // Process the file stream
            using var stream = file.OpenReadStream();
            using var reader = new StreamReader(stream);
            
            string line;
            bool headerLine = false;
            while ((line = await reader.ReadLineAsync()) != null)
            {
                string[] values = line.Split(';'); // Adjust delimiter as needed
                maxColumns = values.Length;
                double?[] valuesDouble = new double?[maxColumns];
                for (int i = 0; i < maxColumns; i++)
                {
                    double valDouble;
                    if(values[i] == "")
                    {
                        valuesDouble[i] = null;
                        headerLine = false;
                    }
                    else
                    {
                        if (Double.TryParse(values[i], out valDouble))
                        {
                            valuesDouble[i] = valDouble;
                            headerLine = false;
                        }
                        else
                        {
                            headerLine = true;
                        }         
                    }           
                }
                if (headerLine)
                {
                    headerData = values;                
                }
                else
                {
                    valueData.Add(valuesDouble);            
                }
            }      
            showChart = true;                       
        }
    }    

@inject ISnackbar Snackbar
@inject ILogger<MudInputWithUnitAdornment> logger
<MudPaper Elevation="1" Class="py-6" Style="@($"position: {DataUtils.FLOATING_POSITION}; background:{DataUtils.FLOATING_COLOUR};")" >              
    <MudPaper Class="mx-4 my-4">
        <br/>
        <MudPaper Class="my-4 mx-4" Style="@($"background:{Colors.Gray.Lighten4};")">          
            <MudText Class="my-2 mx-1" Typo="Typo.h6"><b>Fluid Description</b></MudText>                        
            <MudGrid Class="mx-3 pb-4"> 
                <MudItem xs="3" Class ="mx-2 my-2">
                    <MudTextField @bind-Value="@drillingFluidDescriptionInstance.Name" Label="Name" ShrinkLabel/>
                </MudItem>
                <MudItem xs="5" Class ="mx-2 my-2">
                    <MudTextField @bind-Value="@drillingFluidDescriptionInstance.Description" Label="Description" ShrinkLabel/>
                </MudItem>
            </MudGrid>
        </MudPaper>                
        <MudPaper Class="my-4 mx-4" Style="@($"background:{Colors.Gray.Lighten4};")">          
            <MudToolBar>          
                <MudText Class="mt-1 mx-2" Typo="Typo.body1"><b>Fluid Composition</b></MudText>                        
                <MudSpacer/>
                <MudButton StartIcon="@Icons.Material.Outlined.Add" IconColor="@Color.Success" OnClick="@OpenBrineAddPanel">Add brine</MudButton>                          
                <MudButton StartIcon="@Icons.Material.Outlined.Add" IconColor="@Color.Success" OnClick="@OpenBaseOilAddPanel">Add base oil</MudButton>                                    
                <MudButton Class="mx-2" StartIcon="@showCompositionIcon" OnClick="OpenAndCloseCompositionTab " Size="Size.Medium"/>               
            </MudToolBar>
            <MudCollapse Expanded="@showComposition">
                <MudDivider Class="pb-2"/>            
                <MudGrid Class="mx-3 pb-4"> 
                    <MudItem xs="5">
                        <MudSelect T="Brine" Value="@selectedBrine" Label="Brine Composition"
                            ValueChanged="UpdatedBrineSelection" Text="@(MudSelectText(selectedBrine))">
                            @if(availableBrine.Count > 0)
                            {
                                @foreach(Brine brine in availableBrine)
                                {
                                    <MudSelectItem Value="@brine">@brine.Name</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="3">
                        @if(selectedBrine != null)
                        {
                            <MudInputWithUnitAdornment VariantType="Variant.Text"
                                QuantityLabel="Brine Mass Fraction" QuantityName="MassDrilling"
                                SIValueNullable="@brineMassFraction"
                                SIValueNullableChanged="@UpdateBrineMassFraction"/>
                        }
                    </MudItem> 
                    <MudItem xs="3">
                        <MudInputWithUnitAdornment VariantType="Variant.Text"
                                QuantityLabel="Water/Oil ratio" QuantityName=""
                                SIValueNullable="@waterOilRatio"
                                SIValueNullableChanged="@UpdateWaterOilRatio"/>                          
                    </MudItem>                        
                    <MudItem xs="5">
                        <MudSelect T="BaseOil" Value="@selectedBaseOil" Label="Base Oil Composition" 
                            ValueChanged="UpdatedBaseOilSelection" Text="@(MudSelectText(selectedBaseOil))">
                            @if(availableBaseOil.Count > 0)
                            {
                                @foreach(BaseOil baseOil in availableBaseOil)
                                {
                                    <MudSelectItem Value="@baseOil">@baseOil.Name</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="3">
                        @if(selectedBaseOil != null)
                        {
                            <MudInputWithUnitAdornment VariantType="Variant.Text"
                                QuantityLabel="Base Oil Mass Fraction" QuantityName="MassDrilling"
                                SIValueNullable="@baseOilMassFraction"
                                SIValueNullableChanged="@UpdateBaseOilMassFraction"/>
                        }     
                    </MudItem>                    
                    <FluidComposition DrillingFluidCompositionInstance="@currentComposition"/>
                    <br/>   
                </MudGrid>
            </MudCollapse>
        </MudPaper>
        <FluidThemophysicalEdit FluidDescription="@drillingFluidDescriptionInstance"/>
        <GellingPropertiesPanel GellingProperties="@gellingProperties"/>
        <FlowCurvePanel FlowCurve="flowCurve"/>
        <MudToolBar>
            <MudButton StartIcon="@Icons.Material.Outlined.Save" IconColor="@Color.Primary" 
                OnClick="@AddDrillingFluidDescription">Add new</MudButton>  
            @if(FluidDescriptionId != null)
            {
                <MudButton StartIcon="@Icons.Material.Outlined.Save" IconColor="@Color.Primary" 
                    OnClick="@EditDrillingFluidDescription">Save changes</MudButton>  
            }
            <MudSpacer/>
            <MudButton StartIcon="@Icons.Material.Outlined.Close" IconColor="@Color.Error" 
                OnClick="@CloseAddPanel">Close</MudButton>                    
        </MudToolBar>
    </MudPaper>
</MudPaper>

@if(showBrineAddPanel)
{
    <BrineAddAndEdit BrineId="null" OnMessageSent="@UpdatedBrineListAsync"/>
}
@if(showBaseOilAddPanel)
{
    <BaseOilAddAndEdit BaseOilId="null" OnMessageSent="@UpdatedBaseOilListAsync"/>
}

@code{
    [CascadingParameter]
    private MudUnitAndReferenceChoiceTag? Parent { get; set; }
    [Parameter]
    public Guid? FluidDescriptionId {get; set;} = null;
    [Parameter]
    public EventCallback OnMessageSent {get; set;}   
    //Initialize fluid description 
    private List<Brine> availableBrine = new();
    private List<BaseOil> availableBaseOil = new();
    private Brine? selectedBrine = null;
    private BaseOil? selectedBaseOil = null;
    private double? brineMassFraction = null;
    private double? baseOilMassFraction = null;
    private double? waterOilRatio;
    private BaseCompositionProperties? lowGravitySolid;
    private BaseCompositionProperties? highGravitySolid;
    private List<LostCirculationMaterial>? lostCirculationMaterials;
    //WebApp GUI flow control
    private string showCompositionIcon = Icons.Material.Filled.ExpandLess;
    private bool showComposition = true;
    private bool showBrineAddPanel = false;
    private bool showBaseOilAddPanel = false;
    //Used variables
    private DrillingFluidDescription drillingFluidDescriptionInstance = PseudoConstructors.ConstructDrillingFluidDescription();
    private DrillingFluidComposition currentComposition = PseudoConstructors.ConstructDrillingFluidComposition();
    private GellingProperties gellingProperties = PseudoConstructors.ConstructGellingProperties();
    private FlowCurve flowCurve = PseudoConstructors.ConstructFlowCurve();
    private async Task UpdatedBrineListAsync()
    {
        showBrineAddPanel = false;
        logger.LogInformation("Trying to load list of Brine from client: " + APIUtils.HttpClientDrillingFluid);
        var brineTask = APIUtils.ClientDrillingFluid.GetAllBrineAsync();        
        List<Task> loadingTaskList = new List<Task> { brineTask };
        Task finishedTask = await Task.WhenAny(loadingTaskList);
        if (finishedTask == brineTask)
        {
            try
            {
                availableBrine = (List<Brine>)await brineTask; // awaiting the finished task allows to retrieve its result and throw exception if needed
                if (availableBrine != null)
                {
                    availableBrine.Sort((f1, f2) => f1.Name.CompareTo(f2.Name));
                }
                else
                {
                    logger.LogWarning("Returned list of brine were null on initialization");
                    Snackbar.Add("Returned list of brine were null on initialization", Severity.Warning);
                }
            }
            catch (ApiException ex)
            {
                logger.LogError(ex, "Impossible to load brine from client");
            }
        }
    }
    private async Task UpdatedBaseOilListAsync()
    {
        showBaseOilAddPanel = false;
        //Load available base oil data
        // Starting all loading tasks asynchronously
        logger.LogInformation("Trying to load list of BaseOil from client: " + APIUtils.HttpClientDrillingFluid);
        var baseOilTask = APIUtils.ClientDrillingFluid.GetAllBaseOilAsync();        
        List<Task> loadingTaskList = new List<Task> { baseOilTask };
        Task finishedTask = await Task.WhenAny(loadingTaskList);
        if (finishedTask == baseOilTask)
        {
            try
            {
                availableBaseOil = (List<BaseOil>)await baseOilTask; // awaiting the finished task allows to retrieve its result and throw exception if needed
                if (availableBaseOil != null)
                {
                    availableBaseOil.Sort((f1, f2) => f1.Name.CompareTo(f2.Name));
                }
                else
                {
                    logger.LogWarning("Returned list of base oil were null on initialization");
                    Snackbar.Add("Returned list of base oil were null on initialization", Severity.Warning);
                }
            }
            catch (ApiException ex)
            {
                logger.LogError(ex, "Impossible to load base oil from client");
            }
        }        

    }
    protected override async Task OnInitializedAsync()
    {
        await UpdatedBrineListAsync();
        await UpdatedBaseOilListAsync();        
        await InvokeAsync(() => { StateHasChanged(); });
    }
    protected override async Task OnParametersSetAsync()
    {
        if (FluidDescriptionId != null)
        {
            try
            {
                drillingFluidDescriptionInstance = await APIUtils.ClientDrillingFluid.GetDrillingFluidDescriptionByIdAsync((Guid)FluidDescriptionId);
                if (drillingFluidDescriptionInstance != null)
                {
                    currentComposition = drillingFluidDescriptionInstance.DrillingFluidComposition;
                    gellingProperties = drillingFluidDescriptionInstance.GellingProperties;
                    flowCurve = drillingFluidDescriptionInstance.FlowCurve;
                }
                else
                {
                    logger.LogWarning("Returned drilling fluid description was null on initialization");
                    Snackbar.Add("Returned drilling fluid description was null on initialization", Severity.Warning);
                }
            }
            catch (ApiException ex)
            {
                logger.LogError(ex, "Impossible to load drilling fluid description from client");
            }
        }
    }
    private async Task SendMessage()
    {
        showBrineAddPanel = false;
        showBaseOilAddPanel = false;
        await OnMessageSent.InvokeAsync();
    }
    void OpenBrineAddPanel()
    {
        showBrineAddPanel = true;
        showBaseOilAddPanel = false;
    }
    void OpenBaseOilAddPanel()
    {
        showBaseOilAddPanel = true;
        showBrineAddPanel = false;
    }
    private async Task AddDrillingFluidDescription()
    {
        try
        {
            //Check if inputs are correct            
            if (selectedBrine != null)
                currentComposition.BrineProperies = selectedBrine;
            if (selectedBaseOil != null)
                currentComposition.BaseOilProperies = selectedBaseOil;
            
            drillingFluidDescriptionInstance.MetaInfo = new MetaInfo{ID = Guid.NewGuid()};
            drillingFluidDescriptionInstance.GellingProperties = gellingProperties;
            drillingFluidDescriptionInstance.FlowCurve = flowCurve;
            drillingFluidDescriptionInstance.DrillingFluidComposition = currentComposition;
            
            await APIUtils.ClientDrillingFluid.PostDrillingFluidDescriptionAsync(drillingFluidDescriptionInstance);
            logger.LogInformation("Fluid description posted successfully");
            Snackbar.Add("Fluid description posted successfully", Severity.Success);            
            showBaseOilAddPanel = false;
            showBrineAddPanel = false;        
            await SendMessage();        
        }        
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to add a new fluid description");
            Snackbar.Add("Impossible to add a new fluid description", Severity.Warning);
        }
    }
        private async Task EditDrillingFluidDescription()
    {
        try
        {
            //Check if inputs are correct            
            if (selectedBrine != null)
                currentComposition.BrineProperies = selectedBrine;
            if (selectedBaseOil != null)
                currentComposition.BaseOilProperies = selectedBaseOil;
            
            drillingFluidDescriptionInstance.GellingProperties = gellingProperties;
            drillingFluidDescriptionInstance.FlowCurve = flowCurve;
            drillingFluidDescriptionInstance.DrillingFluidComposition = currentComposition;
            
            await APIUtils.ClientDrillingFluid.PutDrillingFluidDescriptionByIdAsync(drillingFluidDescriptionInstance.MetaInfo.ID, drillingFluidDescriptionInstance);
            logger.LogInformation("Fluid description updated successfully");
            Snackbar.Add("Fluid description updated successfully", Severity.Success);            
            showBaseOilAddPanel = false;
            showBrineAddPanel = false;        
            await SendMessage();        
        }        
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to update fluid description");
            Snackbar.Add("Impossible to update fluid description", Severity.Warning);
        }
    }
    private async Task CloseAddPanel()
    {
        await SendMessage();
    }
    void OpenAndCloseCompositionTab()
    {
        //Control collapse of this property
        if (showComposition)
        {
            showCompositionIcon = Icons.Material.Filled.ExpandMore;     
        }    
        else
        {
            showCompositionIcon = Icons.Material.Filled.ExpandLess;
        }
        showComposition = !showComposition;
    }
    // Unit control code
    private void ManageUnits(){}
    private void UpdatedBrineSelection(Brine brine)
    {
        showBrineAddPanel = false;
        selectedBrine = brine;
        brineMassFraction = brine.MassFraction.GaussianValue.Mean;
        currentComposition.BrineProperies = brine;
    }
    private void UpdatedBaseOilSelection(BaseOil baseOil)
    {
        showBaseOilAddPanel = false;
        selectedBaseOil = baseOil;
        baseOilMassFraction = baseOil.MassFraction.GaussianValue.Mean;
        currentComposition.BaseOilProperies = baseOil;
    }
    private void UpdateWaterOilRatio(double? val)
    {
        waterOilRatio = val;
        currentComposition.WaterOilRatio = ConversionsFromOSDC.DoubleToGaussian(val);
    }
    private void UpdateLowGravitySolid(double? val)
    {
    }
    private void UpdateHighGravitySolid(double? val)
    {
    }
    private void UpdateLostMaterial(double? val)
    {
    }
    private string MudSelectText(Brine? brine)
    {
        if(brine==null)
        {
            return "";        
        }
        else
        {
            return $"{brine.Name}";
        }
    }
    private string MudSelectText(BaseOil? baseOil)
    {
        if(baseOil==null)
        {
            return "";
        }
        else
        {
            return $"{baseOil.Name}";
        }
    }
    private void UpdateBrineMassFraction(double? val)
    {
        if (selectedBrine != null)
        {
            brineMassFraction = val;
            selectedBrine.MassDensity.GaussianValue.Mean = val;
            currentComposition.BrineProperies = selectedBrine;
        }
    }
    private void UpdateBaseOilMassFraction(double? val)
    {
        if (selectedBaseOil != null)
        {
            baseOilMassFraction = val;
            selectedBaseOil.MassDensity.GaussianValue.Mean = val;
            currentComposition.BaseOilProperies = selectedBaseOil;
        }
    }

}